{
  "name": "trofeo-vision-studio",
  "productName": "Trofeo Vision Studio",
  "private": true,
  "version": "1.11.8",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "electron": "electron .",
    "app": "electron .",
    "test": "vitest run",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/orbitron": "^5.2.8",
    "@fontsource/rajdhani": "^5.2.7",
    "electron-updater": "^6.8.9",
    "konva": "^10.3.0",
    "lucide-react": "^1.23.0",
    "motion": "^12.42.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-konva": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.0.12",
    "jsdom": "^29.1.1",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.9"
  },
  "build": {
    "appId": "com.nekun.trofeo-vision-studio",
    "directories": {
      "output": "release"
    },
    "productName": "Trofeo Vision Studio",
    "files": [
      "electron/**",
      "dist/**",
      "build/icon.ico",
      "build/icon.png",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../build/server",
        "to": "backend"
      },
      {
        "from": "../libs",
        "to": "backend/libs"
      },
      {
        "from": "../redist",
        "to": ".",
        "filter": [
          "PawnIO_setup.exe"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Nekunegi",
        "repo": "TrofeoVisionStudio"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "runAfterFinish": false,
      "include": "electron/installer.nsh",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    }
  }
}
