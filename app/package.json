{
  "name": "trofeo-vision-studio",
  "productName": "Trofeo Vision Studio",
  "private": true,
  "version": "1.7.1",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "electron": "electron .",
    "app": "electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/orbitron": "^5.2.8",
    "@fontsource/rajdhani": "^5.2.7",
    "konva": "^10.3.0",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-konva": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.0.12",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  },
  "build": {
    "appId": "com.nekun.trofeo-vision-studio",
    "directories": {
      "output": "release"
    },
    "productName": "Trofeo Vision Studio",
    "files": [
      "electron/**",
      "dist/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../build/server",
        "to": "backend"
      },
      {
        "from": "../libs",
        "to": "backend/libs"
      },
      {
        "from": "../redist/PawnIO_setup.exe",
        "to": "PawnIO_setup.exe"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "runAfterFinish": false,
      "include": "electron/installer.nsh"
    }
  }
}
